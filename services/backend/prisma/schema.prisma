generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  pending
  queued
  processing
  completed
  failed
  retrying
  dead_lettered
}

enum JobType {
  email_simulation
  image_processing_simulation
  report_generation
}

enum JobLogLevel {
  info
  warn
  error
}

model Job {
  id           String      @id @default(uuid())
  type         JobType
  payload      Json
  status       JobStatus
  priority     Int         @default(0)
  delayMs      Int         @default(0)
  attempts     Int         @default(0)
  maxAttempts  Int
  result       Json?
  errorMessage String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  startedAt    DateTime?
  completedAt  DateTime?
  nextRetryAt  DateTime?
  bullJobId    String?     @unique
  logs         JobLog[]

  @@index([status])
  @@index([type])
  @@index([createdAt(sort: Desc)])
}

model JobLog {
  id        String      @id @default(uuid())
  jobId      String
  level      JobLogLevel
  message    String
  metadata   Json?
  createdAt  DateTime    @default(now())
  job        Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt(sort: Desc)])
}
