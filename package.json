{
  "name": "distributed-job-queue-system",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "services/backend",
    "services/web"
  ],
  "scripts": {
    "dev:api": "npm run dev:api --workspace @distributed-job-queue/backend",
    "dev:worker": "npm run dev:worker --workspace @distributed-job-queue/backend",
    "dev:web": "npm run dev --workspace @distributed-job-queue/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspace @distributed-job-queue/backend",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "db:generate": "npm run prisma:generate --workspace @distributed-job-queue/backend",
    "db:migrate": "npm run prisma:migrate --workspace @distributed-job-queue/backend",
    "db:deploy": "npm run prisma:deploy --workspace @distributed-job-queue/backend",
    "seed": "npm run seed --workspace @distributed-job-queue/backend"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.9.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript": "^6.0.2"
  }
}
